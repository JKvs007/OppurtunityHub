rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Opportunities - anyone can read, authenticated users can write
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if true;
    }

    // User profiles - anyone can read/write (for static site without enforced auth)
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
